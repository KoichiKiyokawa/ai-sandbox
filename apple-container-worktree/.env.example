# Optional overrides. Copy to .env and adjust as needed.

# DNS suffix for container hostnames. See README -> "DNS setup".
# local: nice names, but needs sudo setup once + may conflict with macOS mDNS.
# test : pre-provisioned by apple container, works with zero setup.
AC_DOMAIN=test

# Override images if you want different versions.
# AC_POSTGRES_IMAGE=docker.io/library/postgres:17
# AC_REDIS_IMAGE=docker.io/library/redis:7-alpine

# Force a specific published API port (default: 8080 for main, 18xxx for linked).
# AC_API_PORT=9000
