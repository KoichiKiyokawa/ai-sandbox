{
  "name": "devenv-sandbox",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless run --force --name echodeck vite dev --clearScreen=false",
    "build": "vite build",
    "start": "node dist/server/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "DATABASE_URL=postgres://unused drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/react-start": "1.167.43",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.11.0",
    "postgres": "3.4.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "4.2.4"
  },
  "devDependencies": {
    "@rsbuild/core": "2.0.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "0.31.10",
    "portless": "0.10.3",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  }
}
